{
  "expo": {
    "name": "HECE: Türkçe Kelime Oyunu",
    "slug": "dagarcik",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F6F2"
    },
    "ios": {
      "bundleIdentifier": "com.monalterego.hece",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.monalterego.hece",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F6F2"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8017334395191649~8645262458",
          "iosAppId": "ca-app-pub-8017334395191649~5041893519"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b99eff5d-aaef-4979-b96f-28c12c72321e"
      }
    },
    "owner": "monalterego"
  }
}
