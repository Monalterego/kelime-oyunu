ry":"isim","example":""},{"word":"mahzuz","length":6,"definition":"Haz duymuş, hoşlanmış","origin":"Arapça","category":"sıfat","example":""},{"word":"çimçim","length":6,"definition":"Ege Bölgesi’ne özgü, haşlanarak, kızartılarak, sotelenerek yenebilen, lezzetli, aynı zamanda levrek, karagöz, lagos vb. balıkların avlanmasında cansız yem olarak kullanılan küçük karides","origin":"","category":"isim","example":""},{"word":"namına","length":6,"definition":"Adına, kendisine","origin":"","category":"zarf","example":""},{"word":"kaftan","length":6,"definition":"Çoğu ipekten yapılan, bir tür uzun, süslü üst giysisi","origin":"","category":"isim","example":""},{"word":"solmak","length":6,"definition":"Rengini yitirmek, rengi uçmak","origin":"","category":"nesnesiz","example":""},{"word":"toyluk","length":6,"definition":"Toy (I) olma durumu","origin":"","category":"isim","example":""},{"word":"zırnık","length":6,"definition":"Herhangi bir şeyin en küçük, önemsiz ve işe yaramaz parçası","origin":"Farsça","category":"isim","example":""},{"word":"tecdit","length":6,"definition":"Bir şeyi yenileme","origin":"Arapça","category":"isim","example":""},{"word":"Bitlis","length":6,"definition":"Türkiye'nin Doğu Anadolu Bölgesi'nde yer alan illerinden biri","origin":"","category":"isim","example":""},{"word":"zikzak","length":6,"definition":"Art arda birdenbire ters yöne açılar yapan kırık çizgi","origin":"Fransızca","category":"isim","example":""},{"word":"hayvan","length":6,"definition":"Duygu ve hareket yeteneği olan, içgüdüleriyle hareket eden canlı yaratık","origin":"Arapça","category":"isim","example":""},{"word":"eşitçi","length":6,"definition":".......lik yanlısı olan; müsavatçı","origin":"","category":"sıfat","example":""},{"word":"papazi","length":6,"definition":"İnce dokunmuş, mavi, pembe, fıstıki renklerde ipek kumaş","origin":"Yunanca","category":"isim","example":""},{"word":"çelmek","length":6,"definition":"Ayak uzatarak birisini düşürmek","origin":"","category":"-i","example":""},{"word":"mümkün","length":6,"definition":"Gerçekleşme imkânı bulunan; olası","origin":"Arapça","category":"sıfat","example":""},{"word":"münadi","length":6,"definition":"Kamuya duyurulmak istenilen şeyleri yüksek sesle haber vermeyi iş edinmiş olan kimse","origin":"Arapça","category":"isim","example":""},{"word":"mantık","length":6,"definition":"Doğru düşünme sanatı ve bilimi","origin":"Arapça","category":"isim","example":""},{"word":"pusula","length":6,"definition":"Üzerinde kuzey güney doğrultusunu gösteren bir mıknatıs iğnesi bulunan ve yön tespit etmek için kullanılan kadranlı araç; yön belirteci","origin":"İtalyanca","category":"isim","example":""},{"word":"merhem","length":6,"definition":"Deriye sürülerek kullanılan, içinde birçok etken madde bulunan, yumuşak ve koyu kıvamda, yağlı ilaç","origin":"Arapça","category":"isim","example":""},{"word":"bezmek","length":6,"definition":"Bezgin duruma gelmek","origin":"","category":"-den","example":""},{"word":"Düldül","length":6,"definition":"Mekanik olarak çalışan oyuncak çocuk arabası","origin":"Arapça","category":"isim","example":""},{"word":"kaleci","length":6,"definition":"Topla oynanan bazı takım oyunlarında kalenin önünde durarak topun kaleye girmesini önlemekle görevli oyuncu; file bekçisi","origin":"","category":"isim","example":""},{"word":"sudoku","length":6,"definition":"Dokuzar hücreden oluşan dokuz eşit kutuya bölünmüş bir alan üzerinde birden dokuza kadar olan sayıları tekrar etmeyecek şekilde dizmeye dayalı bir zekâ oyunu","origin":"Japonca","category":"isim","example":""},{"word":"reklam","length":6,"definition":"Bir şeyi halka tanıtmak, beğendirmek ve böylelikle sürümünü sağlamak için denenen her türlü yol","origin":"Fransızca","category":"isim","example":""},{"word":"pereme","length":6,"definition":"Bordası çok kavisli, ön ve kıç tarafları yüksek, gondola benzeyen, yakın sahillerde yük ve hayvan taşımacılığında kullanılan bir kayık; peleme","origin":"Rumca","category":"isim","example":""},{"word":"cabası","length":6,"definition":"Artısı, fazladan kazanılanı, elde edileni","origin":"","category":"zarf","example":""},{"word":"püskül","length":6,"definition":"Bir ucundan bazı şeylere süs olarak takılan, diğer ucu serbest saçak biçimindeki iplik demeti","origin":"","category":"isim","example":""},{"word":"vükela","length":6,"definition":"Osmanlı Devleti'nde bakanlar, vekiller","origin":"Arapça","category":"isim","example":""},{"word":"alfabe","length":6,"definition":"Bir dilin seslerini gösteren, belirli bir sıraya göre dizilmiş belli sayıda harfin bütünü; abece, yazı (I)","origin":"Fransızca","category":"isim","example":""},{"word":"Ceyhan","length":6,"definition":"Adana iline bağlı ilçelerden biri","origin":"","category":"isim","example":""},{"word":"kavela","length":6,"definition":"Halatların dikişlerinde kullanılan demir veya ağaç kama","origin":"İtalyanca","category":"isim","example":""},{"word":"Korgun","length":6,"definition":"Çankırı iline bağlı ilçelerden biri","origin":"","category":"isim","example":""},{"word":"ulumak","length":6,"definition":"Köpek, kurt, çakal vb. hayvanlar uzun, iniltili, ağlar gibi bir ses çıkarmak","origin":"","category":"nesnesiz","example":""},{"word":"şömine","length":6,"definition":"Odalarda, genellikle duvar kenarlarında tuğla veya taştan yapılmış, bacası olan yer; ocak","origin":"Fransızca","category":"isim","example":""},{"word":"lojman","length":6,"definition":"Kurum, kuruluş veya iş yerindeki çalışanlara parasız veya az bir kira karşılığında oturmaları için tahsis edilen konut","origin":"Fransızca","category":"isim","example":""},{"word":"pazval","length":6,"definition":"Kunduracıların çalışırken kundurayı dizleri üzerinde tutmak için kullandıkları kayış","origin":"","category":"isim","example":""},{"word":"çatana","length":6,"definition":"Filika büyüklüğünde, islimle işleyen deniz teknesi, küçük vapur; istimbot","origin":"(Çetene","category":"isim","example":""},{"word":"nalbur","length":6,"definition":"At nalı yapan demirci","origin":"Arapça","category":"isim","example":""},{"word":"jorjet","length":6,"definition":"Bürümcük görünüşlü, çok bükümlü, genellikle pamuk iplikleri ile dokunmuş bir kumaş","origin":"Fransızca","category":"isim","example":""},{"word":"doymuş","length":6,"definition":"Bir şey yiyerek tok duruma gelmiş","origin":"","category":"sıfat","example":""},{"word":"temmuz","length":6,"definition":"Yılın yedinci ayı; orak ayı","origin":"Arapça","category":"isim","example":""},{"word":"devren","length":6,"definition":"Devir yoluyla, devrederek","origin":"Arapça","category":"zarf","example":""},{"word":"barlam","length":6,"definition":"İnce pullu, sırtı açık kahverengi, yanları ve karnı beyaz, ortalama 30-40 santimetre boyunda, Marmara ve Ege deniziyle Akdeniz'de bol bulunan bir tür balık (Merluccius merluccius)","origin":"Rumca","category":"isim","example":""},{"word":"erotik","length":6,"definition":"Cinsel duyumlar veya onlara bağlı olan duyumların uyandırdığı duygu ve coşkularla ilgili olan; kösnül, şehvani, şehevi, erosal","origin":"Fransızca","category":"sıfat","example":""},{"word":"ihamlı","length":6,"definition":"İmalı, kinayeli olan","origin":"","category":"sıfat","example":""},{"word":"uzaylı","length":6,"definition":"Uzayda yaşadığı varsayılan (canlı)","origin":"","category":"sıfat","example":""},{"word":"Gördes","length":6,"definition":"Manisa iline bağlı ilçelerden biri","origin":"","category":"isim","example":""},{"word":"harçlı","length":6,"definition":"Yapılması için harç ödenen","origin":"","category":"sıfat","example":""},{"word":"mergup","length":6,"definition":"Sevilip aranan, istenilen, beğenilen, rağbet edilen","origin":"Arapça","category":"sıfat","example":""},{"word":"kemane","length":6,"definition":"Keman ve kemençe yayı","origin":"Farsça","category":"isim","example":""},{"word":"trakit","length":6,"definition":"Yanardağ kayalıkları arasında bulunan bir feldspat türü","origin":"Fransızca","category":"isim","example":""},{"word":"lezzet","