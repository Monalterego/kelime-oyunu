gory":"isim","example":""},{"word":"taze","length":4,"definition":"Bozulmamış, bayatlamamış olan","origin":"Farsça","category":"sıfat","example":""},{"word":"halt","length":4,"definition":"Uygunsuz söz söyleme, uygunsuz iş yapma","origin":"Arapça","category":"isim","example":""},{"word":"ergi","length":4,"definition":"İyi bir şeye erişme durumu","origin":"","category":"isim","example":""},{"word":"emel","length":4,"definition":"Gerçekleştirilmesi zamana bağlı istek","origin":"Arapça","category":"isim","example":""},{"word":"sayı","length":4,"definition":"Sayma, ölçme, tartma vb. işlerin sonucunda ortaya çıkan birimlerin kaç olduğunu bildiren sözlerden her biri; adet","origin":"","category":"isim","example":""},{"word":"izci","length":4,"definition":"İz güderek aradığını bulabilen kimse; keşşaf","origin":"","category":"isim","example":""},{"word":"asık","length":4,"definition":"Kızgınlık, öfke ve hoşnutsuzluk ifade eden (yüz)","origin":"","category":"sıfat","example":""},{"word":"ulan","length":4,"definition":"Öfke, şaşkınlık ve nefret anlatan bir seslenme sözü; lan, ülen","origin":"","category":"ünlem","example":""},{"word":"nova","length":4,"definition":"Parlaklığı birdenbire artan, patlamalı değişen yıldız","origin":"Latince","category":"isim","example":""},{"word":"mine","length":4,"definition":"Metal eşya üzerine vurulan renkli cam katmanı","origin":"Farsça","category":"isim","example":""},{"word":"ezel","length":4,"definition":"Başlangıcı belli olmayan zaman; öncesizlik","origin":"Arapça","category":"isim","example":""},{"word":"cılk","length":4,"definition":"Bozularak kokmuş (yumurta)","origin":"","category":"sıfat","example":""},{"word":"boya","length":4,"definition":"Renk vermek, dış etkilerden korumak için eşyanın üzerine sürülen veya içine katılan madenî, bitkisel veya sentetik madde","origin":"","category":"isim","example":""},{"word":"kaju","length":4,"definition":"Antep fıstığıgillerden, yapraklarını dökmeyen, tropikal bir meyve ağacı; bilader ağacı, Amerikan elması (Anacardium occidentale)","origin":"İngilizce","category":"isim","example":""},{"word":"vadi","length":4,"definition":"İki dağ arasındaki çukurca arazi veya geçit; koyak","origin":"Arapça","category":"isim","example":""},{"word":"yogi","length":4,"definition":"Yoga felsefesini uygulayan kimse","origin":"Sanskrit","category":"isim","example":""},{"word":"viya","length":4,"definition":"Dümeni ortaya alarak gemiyi bulunduğu doğrultuda yürütme","origin":"İtalyanca","category":"isim","example":""},{"word":"Buca","length":4,"definition":"İzmir iline bağlı ilçelerden biri","origin":"","category":"isim","example":""},{"word":"hara","length":4,"definition":"Atların yetiştirildiği ve bakımlarının yapıldığı, hayvanların rahatça hareket etmelerini sağlayan alanların bulunduğu tesis","origin":"Fransızca","category":"isim","example":""},{"word":"roza","length":4,"definition":"Bir tür pembe elmas","origin":"İtalyanca","category":"isim","example":""},{"word":"aday","length":4,"definition":"Bir görev, bir iş için kendini ileri süren veya başkaları tarafından ileri sürülen kimse","origin":"","category":"isim","example":""},{"word":"kese","length":4,"definition":"Cepte taşınan, içine para, tütün vb. konulan, kumaştan veya örgüden küçük torba","origin":"Farsça","category":"isim","example":""},{"word":"icaz","length":4,"definition":"Az sözle çok şey anlatma","origin":"Arapça","category":"isim","example":""},{"word":"börk","length":4,"definition":"Genellikle hayvan postundan yapılan başlık","origin":"","category":"isim","example":""},{"word":"tapa","length":4,"definition":"Şişe gibi dar delikleri tıkamaya yarayan mantar, cam, tahta veya plastikten tıkaç; tıpa","origin":"İtalyanca","category":"isim","example":""},{"word":"tunç","length":4,"definition":"Koyu kızıl renkte olan, bakır, çinko ve kalay alaşımı; bronz","origin":"","category":"isim","example":""},{"word":"uzam","length":4,"definition":"Algılanan nesnelerin temel niteliği","origin":"","category":"isim","example":""},{"word":"ağız","length":4,"definition":"Yüzde, avurtlarla iki çene arasında bulunan, ses çıkarmaya, soluk alıp vermeye yarayan ve besinlerin sindirilmeye başlandığı organ","origin":"","category":"isim","example":""},{"word":"ışık","length":4,"definition":"Cisimleri görmeyi, renkleri ayırt etmeyi sağlayan fiziksel enerji; çerağ, ziya, nur, şavk","origin":"","category":"isim","example":""},{"word":"opak","length":4,"definition":"Donuk, mat (renk)","origin":"Fransızca","category":"sıfat","example":""},{"word":"kalp","length":4,"definition":"Göğüs orta boşluğunda, iki akciğer arasında, vücudun her yanından gelen kirli kanı akciğerlere ve oradan gelen temiz kanı da vücuda dağıtan organ; yürek","origin":"Arapça","category":"isim","example":""},{"word":"adcı","length":4,"definition":".......lık öğretisine bağlı (kimse); isimci","origin":"","category":"sıfat","example":""},{"word":"mapa","length":4,"definition":"Ucu halkalı cıvata","origin":"İtalyanca","category":"isim","example":""},{"word":"kunt","length":4,"definition":"Ağır, kalın, dayanıklı ve sağlam","origin":"Farsça","category":"sıfat","example":""},{"word":"cefa","length":4,"definition":"Bir başkasına verilen aşırı eziyet veya sıkıntı","origin":"Arapça","category":"isim","example":""},{"word":"hamt","length":4,"definition":"Tanrı'ya şükretme","origin":"Arapça","category":"isim","example":""},{"word":"neon","length":4,"definition":"Atom sayısı 10, atom ağırlığı 20,2, yoğunluğu 0,7 olan, sıvı durumuna getirilmiş havadan elde edilerek ışık araçlarında kullanılan, havada pek az olarak bulunan, asal gazlar sınıfından bir element (simgesi Ne)","origin":"Fransızca","category":"isim","example":""},{"word":"oval","length":4,"definition":"Biçimi yumurta gibi olan; yumurtamsı, söbe, beyzi","origin":"Fransızca","category":"sıfat","example":""},{"word":"şilt","length":4,"definition":"Üzerine genellikle bir kurum veya kuruluşun adı, işareti kazınmış veya basılmış olan ve armağan olarak bir kimse veya takıma verilen levha; ergilik","origin":"İngilizce","category":"isim","example":""},{"word":"gücü","length":4,"definition":"Bez tezgâhında ipliği ayarlayan tezgâh tarağı","origin":"","category":"isim","example":""},{"word":"halk","length":4,"definition":"Aynı ülkede yaşayan, aynı kültür özelliklerine sahip olan, aynı uyruktaki insan topluluğu; cumhur, folk","origin":"Arapça","category":"isim","example":""},{"word":"cami","length":4,"definition":"Müslümanların ibadet etmek için toplandıkları yer","origin":"Arapça","category":"isim","example":""},{"word":"geçe","length":4,"definition":"Herhangi bir saat başını .......rek, .......rken","origin":"","category":"zarf","example":""},{"word":"unsu","length":4,"definition":"Un gibi olan, unu andıran","origin":"","category":"sıfat","example":""},{"word":"adil","length":4,"definition":"Adaletle iş gören, adaletten, doğruluktan ayrılmayan, hakkı yerine getiren; adaletli","origin":"Arapça","category":"sıfat","example":""},{"word":"onca","length":4,"definition":"O kadar, o denli","origin":"","category":"sıfat","example":""},{"word":"sıva","length":4,"definition":"Herhangi bir yapıdaki yüzeyleri düzgünleştirmek için kullanılan, yarı akışkan, kum, kireç, çimento karışımı veya çamur harç","origin":"","category":"isim","example":""},{"word":"ağım","length":4,"definition":"Ayağın üstündeki tümsek yer","origin":"","category":"isim","example":""},{"word":"Küre","length":4,"definition":"Bütün noktaları merkezden aynı uzaklıkta bulunan bir yüzeyle sınırlı cisim","origin":"Arapça","category":"isim","example":""},{"word":"kıst","length":4,"definition":"Tartıda, ölçüde, paylaşmalarda adaletli davranma","origin":"Arapça","category":"isim","example":""},{"word":"fava","length":4,"definition":"İçine limon, şeker ve zeytinyağında pembeleştirilmiş soğan koyularak suda haşlanan bakla tanelerinin püre kıvamına getirilmesiyle yapılan ezme","origin":"Rumca","category":"isim","example":""},{"word":"link","length":4,"definition":"Atın eşkin yürüyüşü","origin":"","category":"isim","example":""},{"word":"vali","length":4,"definition":"Bir ilde devleti temsil eden en yetkili yönetim görevlisi; ilbay","origin":"Arapça","category":"isim","example":""},{"word":"mala","length":4,"definition":"Harç alıp sürmeye yarayan, çoğu üçgen biçiminde, yassı biçimli, tahta saplı, demirden sıvama aracı","origin":"Farsça","category":"isim","example":""},{"word":"lenf","length":4,"definition":"Damarlarda dolaşan kanla, doku ögeleri arasında aracı görevi yapan, kan plazması ve .......ositten oluşan saydam, sarı renkte bir sıvı; ak kan, .......a","origin":"Fransızca","category":"isim","example":""},{"word":"otuz","length":4,"definition":"Yirmi dokuzdan sonra gelen sayının adı","origin":"","category":"isim","example":""},{"word":"batı","length":4,"definition":"Bulunulan yerde sola güney, sağa kuzey alındığında yüzün dönük olduğu yön; gün .......sı, günindi, garp, mağrip, doğu karşıtı","origin":"","category":"isim","example":""},{"word":"Tuva","length":4,"definition":"Rusya Federasyonu’na bağlı ....... Özerk Cumhuriyeti’nde yaşayan Türk halkı ve bu halkın soyundan olan kimse","origin":"","category":"isim","example":""},{"word":"saka","length":4,"definition":"Evlere, çeşmeden su taşımayı iş edinmiş olan kimse; sucu","origin":"Arapça","category":"isim","example":""},{"word":"rumi","length":4,"definition":"Anadolu Selçuklularının üsluplaştırdıkları filiz, yaprak ve hayvan motiflerinden oluşmuş dolaşık süsleme","origin":"Arapça","category":"isim","example":""},{"word":"arka","length":4,"definition":"Bir şeyin temel tutulan yüzünün tam ters yanı; ense, ön karşıtı","origin":"","category":"isim","example":""},{"word":"pazı","length":4,"definition":"Ispanakgillerden, sapı ve yaprakları sebze olarak kullanılan bir bitki; yaban pancarı (Beta vulgaris varcicla)","origin":"","category":"isim","example":""},{"word":"enez","length":4,"definition":"Hantal, vurdumduymaz olan","origin":"","category":"sıfat","example":""},{"word":"emik","length":4,"definition":"Emilmekten çürüyen yer","origin":"","category":"isim","example":""},{"word":"defi","length":4,"definition":"Taraflardan birinin kendisine açılan davada borçtan kurtulmak için başvurduğu her türlü yol","origin":"Arapça","category":"isim","example":""},{"word":"uzay","length":4,"definition":"Gök cisimleri de dâhil olmak üzere bütün varlıkların içinde bulunduğu sonsuz boşluk; gök, feza, mekân","origin":"","category":"isim","example":""},{"word":"işte","length":4,"definition":"Bir şey gösterilirken veya bir şeye işaret edilirken söylenen bir söz; aha, ahacık, nah","origin":"","category":"ünlem","example":""},{"word":"acem","length":4,"definition":"Klasik Türk müziğinde kullanılan birleşik bir makam","origin":"Arapça","category":"isim","example":""},{"word":"salı","length":4,"definition":"Pazartesi ile çarşamba arasındaki gün","origin":"","category":"isim","example":""},{"word":"keçi","length":4,"definition":"Geviş getirenlerden, eti, sütü, derisi ve kılı için yetiştirilen, genellikle çenesinde sakalı olan memeli hayvan (Capra hircus)","origin":"","category":"isim","example":""},{"word":"bent","length":4,"definition":"Su biriktirmek için akan suyun önüne yapılan set","origin":"Farsça","category":"isim","example":""},{"word":"etüt","length":4,"definition":"Herhangi bir konuda yapılan inceleme, araştırma","origin":"Fransızca","category":"isim","example":""},{"word":"imza","length":4,"definition":"Bir kimsenin herhangi bir belgeyi yazdığını veya onayladığını belirtmek için her zaman aynı biçimde kullandığı işaret","origin":"Arapça","category":"isim","example":""},{"word":"faiz","length":4,"definition":"İşletmek için bir yere ödünç verilen paraya karşılık alınan kâr; ürem, nema","origin":"Arapça","category":"isim","example":""},{"word":"ekin","length":4,"definition":"Tahılın tarlaya atıldığı andan harman oluncaya kadar aldığı durum; firez","origin":"","category":"isim","example":""},{"word":"aura","length":4,"definition":"Canlıların bedenlerini çevreleyerek kalkan görevi yaptığı varsayılan, katmanlardan oluşan ve kendine özgü rengi olan elektromanyetik alan","origin":"Fransızca","category":"isim","example":""},{"word":"ulum","length":4,"definition":"Bilimler, ilimler","origin":"Arapça","category":"isim","example":""},{"word":"tike","length":4,"definition":"Et, ekmek, peynir vb.nde parça, lokma, dilim","origin":"","category":"isim","example":""},{"word":"ağrı","length":4,"definition":"Sinir uçlarının şiddetli biçimde uyarılmasıyla ortaya çıkan, vücudun herhangi bir yerinde oluşan rahatsızlık hissi; veca","origin":"","category":"isim","example":""},{"word":"sara","length":4,"definition":"Zaman zaman kendini kaybederek olduğu yere düşme, vücutta şiddetli çırpınmalar ve ağız köpürmesi ile ortaya çıkan bir sinir hastalığı; tutarık, tutarak, tutarga, yilbik, epilepsi","origin":"Arapça","category":"isim","example":""},{"word":"akın","length":4,"definition":"Kalabalık bir şeyin arkası kesilmeyen bir geliş durumunda olması","origin":"","category":"isim","example":""},{"word":"obüs","length":4,"definition":"Tank biçiminde veya kamyon, jip vb. bir araçla taşınabilir türleri olan, yüksek ve alçaktan mermi atabilen, orta menzilli, kısa namlulu ateşli silah","origin":"Fransızca","category":"isim","example":""},{"word":"abla","length":4,"definition":"Bir kimsenin kendisinden büyük olan kız kardeşi; aba, bacı","origin":"","category":"isim","example":""},{"word":"fuar","length":4,"definition":"Belli zamanlarda, belli yerlerde ticari mal sergilemek ve satmak amacıyla açılan büyük sergi","origin":"Fransızca","category":"isim","example":""},{"word":"dayı","length":4,"definition":"Annenin erkek kardeşi","origin":"","category":"isim","example":""},{"word":"gibi","length":4,"definition":"-e benzer, -e benzeyen","origin":"","category":"edat","example":""},{"word":"işbu","length":4,"definition":"Bu, özellikle bu","origin":"","category":"sıfat","example":""},{"word":"tarz","length":4,"definition":"Anlatma, oluş, deyiş veya yapış biçimi; minval, usul (II), üslup, vetire, stil, janr, ambiyans","origin":"Arapça","category":"isim","example":""},{"word":"oğuz","length":4,"definition":"İyi huylu (kimse)","origin":"","category":"sıfat","example":""},{"word":"blöf","length":4,"definition":"İskambil oyunlarında elindeki kâğıtları olduğundan başka gösterme davranışı","origin":"Fransızca","category":"isim","example":""},{"word":"narh","length":4,"definition":"Tüketiciyi korumak amacıyla, özellikle temel ihtiyaç maddeleri için resmî makamlarca belirlenen ve her yerde geçerli olan fiyat","origin":"Farsça","category":"isim","example":""},{"word":"staj","length":4,"definition":"Herhangi bir meslek edinecek olan kimsenin geçirdiği uygulamalı öğrenme dönemi","origin":"Fransızca","category":"isim","example":""},{"word":"ülüş","length":4,"definition":"Kesilen hayvanın etinden alınan pay","origin":"","category":"isim","example":""},{"word":"akar","length":4,"definition":"Kiraya verilerek gelir getiren ev, dükkân, tarla, bağ vb. mülk; .......et","origin":"Arapça","category":"isim","example":""},{"word":"bela","length":4,"definition":"İçinden çıkılması güç, sakıncalı durum; beliye","origin":"Arapça","category":"isim","example":""},{"word":"azat","length":4,"definition":"Serbest bırakma","origin":"Farsça","category":"isim","example":""},{"word":"konu","length":4,"definition":".......şmada, yazıda, eserde ele alınan düşünce, olay veya durum; bap, mevzu, süje","origin":"","category":"isim","example":""},{"word":"taba","length":4,"definition":"Kuru tütün yaprağını andıran kızılımsı kahverengi; tütün rengi","origin":"Fransızca","category":"isim","example":""},{"word":"cırt","length":4,"definition":"Kâğıt, kumaş vb. yırtılırken çıkan ses","origin":"","category":"isim","example":""},{"word":"sulp","length":4,"definition":"Bel kemiği, omurga","origin":"Arapça","category":"isim","example":""},{"word":"bant","length":4,"definition":"Yapılış özelliğine göre sarma, yapıştırma, malzemeyi bir yerden başka yere taşıma vb. işlerde yararlanılan, giysilerde süs, işaret vb. için kullanılan, düz, ensiz, yassı şerit; izole .......","origin":"Fransızca","category":"isim","example":""},{"word":"ufak","length":4,"definition":"Boyutları normalden küçük","origin":"","category":"sıfat","example":""},{"word":"sızı","length":4,"definition":"Hafif ve ince ağrı","origin":"","category":"isim","example":""},{"word":"kanı","length":4,"definition":"Bir konuda kesin delillere dayanmadan varılan yargı","origin":"","category":"isim","example":""},{"word":"Kürt","length":4,"definition":"Ön Asya'da yaşayan bir topluluk ve bu topluluktan olan kimse","origin":"","category":"isim","example":""},{"word":"kaos","length":4,"definition":"Evrenin düzene girmeden önceki biçimden yoksun, uyumsuz ve karışık durumu","origin":"Fransızca","category":"isim","example":""},{"word":"zerk","length":4,"definition":"Vücuda şırınga ile sıvı verme işi; iç itme, iç itim","origin":"Arapça","category":"isim","example":""},{"word":"işba","length":4,"definition":"Karnını doyurma","origin":"Arapça","category":"isim","example":""},{"word":"cami","length":4,"definition":"Müslümanların ibadet etmek için toplandıkları yer","origin":"Arapça","category":"isim","example":""},{"word":"Lice","length":4,"definition":"Diyarbakır iline bağlı ilçelerden biri","origin":"","category":"isim","example":""},{"word":"uçar","length":4,"definition":"Uçan, uçucu olan","origin":"","category":"sıfat","example":""},{"word":"asıl","length":4,"definition":"Bir şeyin kendisi, kopya karşıtı","origin":"Arapça","category":"isim","example":""},{"word":"ucuz","length":4,"definition":"Fiyatı yüksek olmayan, pahası az, düşük fiyatlı; ehven, pahalı karşıtı","origin":"","category":"sıfat","example":""},{"word":"siya","length":4,"definition":"Kürekleri tersine kullanarak sandalı geriye yürütme","origin":"Rumca","category":"isim","example":""},{"word":"piko","length":4,"definition":"Kimi örtülerin veya çamaşırların kenarına makineyle yapılan bir süs türü","origin":"Fransızca","category":"isim","example":""},{"word":"spin","length":4,"definition":"“Genellikle gösteri amaçlı olarak aracın arka tarafını kontrollü veya kontrolsüz bir biçimde değişik yönlere savurmak” anlamındaki ....... atmak birleşik fiilinde geçen bir söz","origin":"İngilizce","category":"isim","example":""},{"word":"eter","length":4,"definition":"Oksijenli asitlerin alkollerle birleşmesinden oluşan sıvılar","origin":"Fransızca","category":"isim","example":""},{"word":"obur","length":4,"definition":"Gereğinden çok yemek yiyen, doymak bilmeyen (kimse)","origin":"","category":"sıfat","example":""},{"word":"pota","length":4,"definition":"İçinde maden eritilen kap","origin":"Farsça","category":"isim","example":""},{"word":"raşi","length":4,"definition":"Rüşvet veren kimse","origin":"Arapça","category":"isim","example":""},{"word":"okka","length":4,"definition":"1,282 kilogram veya 400 dirhemlik ağırlık ölçüsü birimi; kıyye","origin":"Arapça","category":"isim","example":""},{"word":"ürat","length":4,"definition":"Sidik asidi tuzu","origin":"Fransızca","category":"isim","example":""},{"word":"şişe","length":4,"definition":"İçerisine sıvı konulan, cam veya plastikten yapılmış, dar ağızlı uzun kap","origin":"Farsça","category":"isim","example":""},{"word":"beze","length":4,"definition":"Yara veya çıban sebebiyle vücudun herhangi bir yerinde oluşan şişkinlik; gudde","origin":"","category":"isim","example":""},{"word":"alev","length":4,"definition":"Yanan maddelerin veya gazların türlü biçimlerdeki ışıklı uzantısı; alaz, yalım, yalın (I), yalaz, yalaza, şule","origin":"","category":"isim","example":""},{"word":"kist","length":4,"definition":"Sporlu bitkilerde, özellikle mantarlarda, su yosunlarında görülen, bir veya birkaç hücreden oluşmuş organ","origin":"Fransızca","category":"isim","example":""},{"word":"küfe","length":4,"definition":"Genellikle söğüt veya başka ağaç dallarından örülen, yük taşımaya yarayan, kaba ve dayanıklı sepet","origin":"Rumca","category":"isim","example":""},{"word":"skif","length":4,"definition":"İçine yalnız kürek çekenin girebildiği çok uzun ve çok dar yarış kayığı","origin":"İngilizce","category":"isim","example":""},{"word":"ödev","length":4,"definition":"Yapılması, yerine getirilmesi, insanlık duygusu, töre ve yasa bakımından gerekli olan iş veya davranış; vazife","origin":"","category":"isim","example":""},{"word":"ağıl","length":4,"definition":"Evcil küçükbaş hayvanların barındığı çit veya duvarla çevrili yer; arkaç","origin":"","category":"isim","example":""},{"word":"eksi","length":4,"definition":"Çıkarma işleminde - işaretinin adı; nakıs","origin":"","category":"isim","example":""},{"word":"cırt","length":4,"definition":"Kâğıt, kumaş vb. yırtılırken çıkan ses","origin":"","category":"isim","example":""},{"word":"trip","length":4,"definition":"Gücenilen bir durumda, açıkça konuşmak yerine farklı söz ve hareketlerle yapılan tavır","origin":"İngilizce","category":"isim","example":""},{"word":"tren","length":4,"definition":"Demir yolunda yolcu ve yük taşımakta kullanılan, bir veya birkaç lokomotif tarafından çekilen vagonlar dizisi; katar, şimendifer","origin":"Fransızca","category":"isim","example":""},{"word":"kore","length":4,"definition":"Başlıca belirtisi kısa, çabuk, değişken yapıda irade dışı hareketler olan bir hastalık","origin":"Yunanca","category":"isim","example":""},{"word":"neli","length":4,"definition":"Genellikle yiyecek, içecek içinde veya içeriğinde bulunan şeyi sorarken kullanılan söz","origin":"","category":"sıfat","example":""},{"word":"gişe","length":4,"definition":"İstasyon, sinema, banka, mağaza ve bazı giriş kapılarında bilet veya para alıp verilen, çoğu küçük pencere biçiminde olan yer; şalter","origin":"Fransızca","category":"isim","example":""},{"word":"Kulp","length":4,"definition":"Kazan, tencere, fincan, dolap, altın vb.nin tutulacak yeri","origin":"Rumca","category":"isim","example":""},{"word":"priz","length":4,"definition":"Elektrik akımı almak için fişin sokulduğu yuva","origin":"Fransızca","category":"isim","example":""},{"word":"şato","length":4,"definition":"Avrupa'da soylu kimselerin oturduğu, çevresi hendek, sur ve kulelerle çevrili konak","origin":"Fransızca","category":"isim","example":""},{"word":"özüt","length":4,"definition":"Bir maddenin herhangi bir yolla elde edilmiş olan özü; ekstre","origin":"","category":"isim","example":""},{"word":"Boğa","length":4,"definition":"Damızlık erkek sığır; kele","origin":"","category":"isim","example":""},{"word":"miza","length":4,"definition":"Kumarda ortaya sürülen para","origin":"İtalyanca","category":"isim","example":""},{"word":"şema","length":4,"definition":"Bir aletin, bir aracın veya bir biçimin ana çizgilerini gösteren çizim","origin":"Fransızca","category":"isim","example":""},{"word":"Yıva","length":4,"definition":"Oğuz Türklerinin yirmi dört boyundan biri","origin":"","category":"isim","example":""},{"word":"fabl","length":4,"definition":"Kahramanları çoklukla hayvanlardan seçilen, sonunda ders verme amacı güden, genellikle manzum hikâye; öykünce","origin":"Fransızca","category":"isim","example":""},{"word":"hare","length":4,"definition":"Bazı nesne, canlı, göz vb.nde dalgalanır gibi görünen parlak çizgiler; meneviş, dalgır","origin":"Farsça","category":"isim","example":""},{"word":"koru","length":4,"definition":"Bakımlı küçük orman","origin":"","category":"isim","example":""},{"word":"rıza","length":4,"definition":"Razı olma, bir şeyi yapmayı isteme; onam","origin":"Arapça","category":"isim","example":""},{"word":"kasa","length":4,"definition":"Para veya değerli eşya saklamaya yarayan çelik dolap","origin":"İtalyanca","category":"isim","example":""},{"word":"avro","length":4,"definition":"Avrupa Birliği'nin ortak para birimi; ekü","origin":"","category":"isim","example":""},{"word":"nane","length":4,"definition":"Ballıbabagillerden, yaprakları sapsız, çiçekleri beyaz veya menekşe renginde, güzel kokulu, yaprakları baharat olarak kullanılan, çok yıllık ve otsu bir kültür bitkisi (Mentha piperita)","origin":"Arapça","category":"isim","example":""},{"word":"razı","length":4,"definition":"Uygun bulan, benimseyen, isteyen, kabul eden","origin":"Arapça","category":"sıfat","example":""},{"word":"golf","length":4,"definition":"Çimenlerle kaplı, açık, geniş bir alanda, ufak bir topu özel sopalarla ilerleterek belli bir deliğe sokma amaçlı oynanan oyun","origin":"Fransızca","category":"isim","example":""},{"word":"hırt","length":4,"definition":"Görgüsüz tavırlı, incelikten uzak olan (kimse)","origin":"","category":"sıfat","example":""},{"word":"skeç","length":4,"definition":"Güldürü niteliğinde kısa oyun","origin":"İngilizce","category":"isim","example":""},{"word":"Kars","length":4,"definition":"Türkiye'nin Doğu Anadolu Bölgesi'nde yer alan illerinden biri","origin":"","category":"isim","example":""},{"word":"çatı","length":4,"definition":"Bir yapının, bir evin damını kuran parçaların bütünü; sakaf","origin":"","category":"isim","example":""},{"word":"ataş","length":4,"definition":"Kâğıtları birbirine tutturmak için kullanılan, telden yapılmış araç; tutturgaç","origin":"Fransızca","category":"isim","example":""},{"word":"zoka","length":4,"definition":"Büyük balıkları tutmakta kullanılan, küçük balık biçiminde, ucu iğneli kurşun parçası","origin":"Rumca","category":"isim","example":""},{"word":"punç","length":4,"definition":"Çay, şeker, tarçın, limon karışımına rom veya kanyak gibi damıtılmış alkollü bir içki katılarak yapılan ve buharlaşan alkolü yakıldıktan sonra içilen bir içki türü","origin":"Fransızca","category":"isim","example":""},{"word":"kova","length":4,"definition":"Genellikle su ve sulu şeyler taşımaya, kuyudan veya denizden su çekmeye yarayan üstünden kulplu kap","origin":"","category":"isim","example":""},{"word":"peni","length":4,"definition":"Sterlinin yüzde biri değerindeki para birimi","origin":"İngilizce","category":"isim","example":""},{"word":"ezan","length":4,"definition":"Müslümanlıkta namaz vaktini bildirmek için müezzinin yüksek sesle yaptığı çağrı","origin":"Arapça","category":"isim","example":""},{"word":"usul","length":4,"definition":"Kökler, asıllar","origin":"Arapça","category":"isim","example":""},{"word":"Fürs","length":4,"definition":"Eski Fars halkından olan kimse","origin":"","category":"isim","example":""},{"word":"onum","length":4,"definition":"Kötü bir durumdan kurtulma","origin":"","category":"isim","example":""},{"word":"kamu","length":4,"definition":"Halk hizmeti gören devlet organlarının tümü","origin":"","category":"isim","example":""},{"word":"hacı","length":4,"definition":"Din buyruklarını yerine getirmek için hacca gitmiş Müslüman","origin":"Arapça","category":"isim","example":""},{"word":"anne","length":4,"definition":"Çocuğu olan kadın; aba (I), ana, kocakarı, nene, valide, mader","origin":"","category":"isim","example":""},{"word":"ağıt","length":4,"definition":"Ölenin iyi niteliklerini, ölümünden duyulan acıyı dile getiren söz veya ezgi","origin":"","category":"isim","example":""},{"word":"şoke","length":4,"definition":"\"Birdenbire şaşırtmak, hoşa gitmeyecek bir şey yapmak\" anlamlarındaki ....... etmek ve \"birdenbire şaşırmak, hoşa gitmeyecek bir şeyle karşılaşmak\" anlamlarındaki ....... olmak deyimlerinde kullanılan bir söz","origin":"Fransızca","category":"sıfat","example":""},{"word":"çaça","length":4,"definition":"Ticaret gemilerinde eski ve usta gemici","origin":"Rumca","category":"isim","example":""},{"word":"ödem","length":4,"definition":"Dokularda, hücreler arası boşluklarda, bazı iç organlarda genellikle de yüzde, ellerde, ayaklarda aşırı miktarda sıvı birikmesi","origin":"Fransızca","category":"isim","example":""},{"word":"onur","length":4,"definition":"İnsanın kendine karşı duyduğu saygı; alicenaplık","origin":"Fransızca","category":"isim","example":""},{"word":"azel","length":4,"definition":"Sunumun birkaç satıcı tarafından yapıldığı ve bu az sayıdaki satıcının birbirlerinin üretim kararlarından etkilendiği piyasa türü; oligopol","origin":"","category":"isim","example":""},{"word":"Kula","length":4,"definition":"Gövdenin sarı veya kirli sarı renkte, yele, kuyruk ve bacağın alt kısmındaki kılların koyu renkte olduğu at donu","origin":"","category":"isim","example":""},{"word":"boci","length":4,"definition":"Ağır yük taşımaya yarayan, iki kalın ve küçük tekerleği olan el arabası","origin":"İtalyanca","category":"isim","example":""},{"word":"plak","length":4,"definition":"Sesleri kaydetmek ve kaydedilen sesleri yeniden pikap veya gramofonda dinlemek amacıyla hazırlanan plastik daire biçiminde yaprak","origin":"Fransızca","category":"isim","example":""},{"word":"elçi","length":4,"definition":"Bir devleti başka bir devlet katında temsil eden kimse; sefir","origin":"","category":"isim","example":""},{"word":"peyk","length":4,"definition":"Haber ve mektup taşıyan kimse","origin":"Farsça","category":"isim","example":""},{"word":"ilca","length":4,"definition":"Zorlama, zorunda bırakma","origin":"Arapça","category":"isim","example":""},{"word":"imha","length":4,"definition":"Ortadan kaldırma, yok etme","origin":"Arapça","category":"isim","example":""},{"word":"ötre","length":4,"definition":"Arap harfli metinlerde bir ünsüzün o, ö, u, ü seslerinden biriyle okunacağını gösteren işaret; zamme","origin":"","category":"isim","example":""},{"word":"iğsi","length":4,"definition":"İğ şeklinde olan, iği andıran","origin":"","category":"sıfat","example":""},{"word":"atak","length":4,"definition":"Düşüncesizce her işe atılan","origin":"","category":"sıfat","example":""},{"word":"eğer","length":4,"definition":"Şart anlamını güçlendirmek için şartlı cümlelerin başına getirilen bir söz; şayet","origin":"Farsça","category":"bağlaç","example":""},{"word":"göre","length":4,"definition":"Bir şeye uygun olarak, bir şey uyarınca; gereğince","origin":"","category":"edat","example":""},{"word":"ocak","length":4,"definition":"Ateş yakmaya yarayan, pişirme, ısıtma, ısınma vb. amaçlarla kullanılan yer; .......lık","origin":"","category":"isim","example":""},{"word":"eski","length":4,"definition":"Çoktan beri var olan, üzerinden çok zaman geçmiş bulunan; ezelî, ihtiyar (I), yeni karşıtı","origin":"","category":"sıfat","example":""},{"word":"şist","length":4,"definition":"Kolayca yapraklara ayrılabilen, silisli, alüminli tortul kayaçların genel adı","origin":"Fransızca","category":"isim","example":""},{"word":"uydu","length":4,"definition":"Bir gezegenin çekiminde bulunarak onun çevresinde dolanan daha küçük gezegen; peyk","origin":"","category":"isim","example":""},{"word":"itap","length":4,"definition":"Paylama, azarlama","origin":"Arapça","category":"isim","example":""},{"word":"Biga","length":4,"definition":"Çanakkale iline bağlı ilçelerden biri","origin":"","category":"isim","example":""},{"word":"izin","length":4,"definition":"Bir şey yapmak için verilen veya alınan özgürlük; cevaz, destur, icazet, müsaade, ruhsat","origin":"Arapça","category":"isim","example":""},{"word":"ipçi","length":4,"definition":"İp üreten, yapan veya satan kimse","origin":"","category":"isim","example":""},{"word":"ibiş","length":4,"definition":"Orta oyununda çoğu kez aptal uşak rolünü oynayan komedyen","origin":"","category":"isim","example":""},{"word":"mudi","length":4,"definition":"Bankaya para yatıran kimse","origin":"Arapça","category":"isim","example":""},{"word":"veli","length":4,"definition":"Bir çocuğu koruyan, işlerine bakan ve her türlü davranışından sorumlu kimse; ege, iye","origin":"Arapça","category":"isim","example":""},{"word":"koma","length":4,"definition":"Bazı hastalıklar, yaralanmalar, zehirlenmeler sırasında görülen anlama, duyma ve hareketin büsbütün veya az çok kaybolmasıyla beliren bilinç kaybı durumu","origin":"Fransızca","category":"isim","example":""},{"word":"kete","length":4,"definition":"Yağlı, mayalı veya mayasız hamurdan yapılan çörek","origin":"","category":"isim","example":""},{"word":"anat","length":4,"definition":"Anlar, zamanlar","origin":"Arapça","category":"isim","example":""},{"word":"edna","length":4,"definition":"Çok aşağı, en alt düzeyde","origin":"Arapça","category":"sıfat","example":""},{"word":"kask","length":4,"definition":"Başı darbelerden korumak için sertleştirilmiş sentetik maddelerden yapılmış sağlam başlık","origin":"Fransızca","category":"isim","example":""},{"word":"kosa","length":4,"definition":"Bir tür uzun saplı orak","origin":"Rusça","category":"isim","example":""},{"word":"Zara","length":4,"definition":"Sivas iline bağlı ilçelerden biri","origin":"","category":"isim","example":""},{"word":"ışın","length":4,"definition":"Bir ışık kaynağından çıkarak her yöne yayılıp giden ışık demeti; şua","origin":"","category":"isim","example":""},{"word":"akça","length":4,"definition":"Beyazımsı, beyaza benzer; ağca","origin":"","category":"sıfat","example":""},{"word":"abak","length":4,"definition":"Eski Türklerde ölmüş kimselerin heykel vb. suretleri","origin":"","category":"isim","example":""},{"word":"kron","length":4,"definition":"Danimarka, Estonya, İsveç, İzlanda, Norveç ve Slovakya'nın para birimi","origin":"","category":"isim","example":""},{"word":"opal","length":4,"definition":"Silisin hidratlı ve jelatinli bütün türlerini kapsayan değerli bir mineral; panzehir taşı","origin":"Fransızca","category":"isim","example":""},{"word":"inal","length":4,"definition":"Kendisine inanılan kimse","origin":"","category":"isim","example":""},{"word":"deli","length":4,"definition":"Aklını yitirmiş olan, akli dengesi bozulmuş olan","origin":"","category":"sıfat","example":""},{"word":"iglu","length":4,"definition":"Çoğunlukla kar bloklarından kubbe biçiminde yapılan ve yalnızca Mackenzie Irmağı deltası ile Labrador arasında kalan bölgede rastlanan Eskimo kulübesi","origin":"İngilizce","category":"isim","example":""},{"word":"ilgi","length":4,"definition":"İki şey arasında bulunan herhangi bir bağlılık; alaka, taalluk","origin":"","category":"isim","example":""},{"word":"edik","length":4,"definition":"Yumuşak ve renkli sahtiyandan yapılmış yarım konçlu bir tür ayakkabı; lapçın","origin":"","category":"isim","example":""},{"word":"algı","length":4,"definition":"Bir şeye dikkati yönelterek o şeyin bilincine varma; idrak","origin":"","category":"isim","example":""},{"word":"eşek","length":4,"definition":"Atgillerden, uzun kulaklı binek ve hizmet hayvanı; merkep, karakaçan, uzun kulaklı (Equus asinus)","origin":"","category":"isim","example":""},{"word":"çete","length":4,"definition":"Yasa dışı işler yapmak veya etrafındakileri korkutmak amacıyla bir araya gelmiş topluluk","origin":"Bulgarca","category":"isim","example":""},{"word":"lota","length":4,"definition":"Tatlı sularda yaşayan, bir tür gelincik balığı (....... vulgaris)","origin":"Latince","category":"isim","example":""},{"word":"blum","length":4,"definition":"Elli iki kâğıt ve iki jokerle, en az iki kişi, en fazla dört kişi tarafından oynanan, konkene benzeyen bir iskambil oyunu","origin":"Fransızca","category":"isim","example":""},{"word":"peçe","length":4,"definition":"Kadınların sokakta yüzlerine örttükleri ince siyah örtü; nikap","origin":"İtalyanca","category":"isim","example":""},{"word":"mazı","length":4,"definition":"Servigillerden, yaprakları almaşık ve küçük pullar biçiminde, gövdesi düz olan, dipten dallanan bir süs bitkisi (Thuya)","origin":"Farsça","category":"isim","example":""},{"word":"elli","length":4,"definition":"Kırk dokuzdan sonra gelen sayının adı","origin":"","category":"isim","example":""},{"word":"pisi","length":4,"definition":"Çocuk dilinde kedi","origin":"","category":"isim","example":""},{"word":"plan","length":4,"definition":"Bir işin, bir eserin gerçekleştirilmesi, bir konunun yolunda yürümesi için uyulması tasarlanan düzen","origin":"Fransızca","category":"isim","example":""},{"word":"şevk","length":4,"definition":"Aşırı heves, aşırı istek","origin":"Arapça","category":"isim","example":""},{"word":"aşçı","length":4,"definition":"Yemek pişirmeyi meslek edinen kimse","origin":"","category":"isim","example":""},{"word":"Sami","length":4,"definition":"Güneybatı Asya ve Kuzey Afrika’da yaşayan ve Hz. Nuh’un oğlu Sâm’ın soyundan geldikleri kabul edilen kavimler topluluğu","origin":"Arapça","category":"isim","example":""},{"word":"ekşi","length":4,"definition":"Sirke veya limon tadında olan","origin":"","category":"sıfat","example":""},{"word":"edat","length":4,"definition":"Ev gibi huzur köşesi olmaz. Çocuk sabaha karşı uyandı","origin":"Arapça","category":"isim","example":""},{"word":"sıma","length":4,"definition":".......k durumu veya biçimi","origin":"","category":"isim","example":""},{"word":"ayan","length":4,"definition":"Gözle görülür bir şekilde açık ve belli olan","origin":"Arapça","category":"sıfat","example":""},{"word":"Orta","length":4,"definition":"Bir şeyin kenarlarından merkeze doğru yaklaşık olarak aynı uzaklıkta olan yer","origin":"","category":"isim","example":""},{"word":"spot","length":4,"definition":"Herhangi bir aynalı alet ile ekran üzerinde oluşturulan görüntü","origin":"Fransızca","category":"isim","example":""},{"word":"yeis","length":4,"definition":"Umutsuzluktan doğan karamsarlık, üzüntü","origin":"Arapça","category":"isim","example":""},{"word":"alfa","length":4,"definition":"Yunan .......besinin birinci harfi","origin":"Fransızca","category":"isim","example":""},{"word":"oluk","length":4,"definition":"Bir şeyin akmasına yarayan üst yanı açık boru","origin":"","category":"isim","example":""},{"word":"adat","length":4,"definition":"Töreler, âdetler","origin":"Arapça","category":"isim","example":""},{"word":"lobi","length":4,"definition":"Bir yapının kapısından içeri girildiğinde görülen ilk boşluk; dalan","origin":"Fransızca","category":"isim","example":""},{"word":"grup","length":4,"definition":"Birbirine benzer veya aynı cinsten olan şeylerin oluşturduğu bütün; küme, takım","origin":"Fransızca","category":"isim","example":""},{"word":"iğde","length":4,"definition":"İğdegillerden, kokulu, sarı çiçekleri olan, çalı biçiminde bir ağaç (Elaeagnus)","origin":"","category":"isim","example":""},{"word":"pisi","length":4,"definition":"Çocuk dilinde kedi","origin":"","category":"isim","example":""},{"word":"tabu","length":4,"definition":"Kutsal sayılan bazı insanlara, hayvanlara, nesnelere dokunulmasını, kullanılmasını yasaklayan, aksi yapıldığında zararı dokunacağı düşünülen dinî inanç","origin":"Fransızca","category":"isim","example":""},{"word":"eşik","length":4,"definition":"Kapı boşluğunun alt yanında bulunan alçak basamak; asitane","origin":"","category":"isim","example":""},{"word":"gürz","length":4,"definition":"Silah olarak kullanılan ağır topuz","origin":"Farsça","category":"isim","example":""},{"word":"uçuş","length":4,"definition":"Uçmak işi; pervaz (II)","origin":"","category":"isim","example":""},{"word":"lüks","length":4,"definition":"Yaşayış, giyim vb. için yapılan harcamada aşırı gitme","origin":"Fransızca","category":"isim","example":""},{"word":"Ağrı","length":4,"definition":"Sinir uçlarının şiddetli biçimde uyarılmasıyla ortaya çıkan, vücudun herhangi bir yerinde oluşan rahatsızlık hissi; veca","origin":"","category":"isim","example":""},{"word":"akva","length":4,"definition":"Bir tür sırmalı ve köstekli bıçak","origin":"","category":"isim","example":""},{"word":"ölçü","length":4,"definition":"Bir niceliği, o nicelik için kabul edilmiş birimlerden birine göre oranlayarak değerlendirme; endaze, mizan","origin":"","category":"isim","example":""},{"word":"Agop","length":4,"definition":"\"Aptal aptal bakmak\" anlamındaki .......'un kazı gibi bakmak, “eline geçeni yalayıp yutmak” anlamındaki .......’un kazı gibi yutmak (veya yemek), “kara kara düşünmek” anlamındaki .......’un kazı gibi düşünmek deyimlerinde geçen bir söz","origin":"Ermenice","category":"isim","example":""},{"word":"mülk","length":4,"definition":"Ev, dükkân, arazi vb. taşınmaz mal","origin":"Arapça","category":"isim","example":""},{"word":"vade","length":4,"definition":"Bir işin yapılması veya bir borcun ödenmesi için tanınan süre; mühlet","origin":"Arapça","category":"isim","example":""},{"word":"yedi","length":4,"definition":"Altıdan sonra gelen sayının adı","origin":"","category":"isim","example":""},{"word":"çuha","length":4,"definition":"Tüysüz, ince, sık dokunmuş yün kumaş","origin":"Farsça","category":"isim","example":""},{"word":"arşe","length":4,"definition":"Tren, troleybüs, tramvay vb. elektrikle işleyen taşıtlarda telden elektrik akımı almaya yarayan, yukarıya doğru uzanmış demir yay","origin":"Fransızca","category":"isim","example":""},{"word":"eyer","length":4,"definition":"Binek hayvanlarının sırtına konulan, oturmaya yarayan nesne","origin":"","category":"isim","example":""},{"word":"amca","length":4,"definition":"Babanın erkek kardeşi; baba yarısı, emmi","origin":"","category":"isim","example":""},{"word":"üçer","length":4,"definition":"Üç sayısının üleştirme sayı sıfatı","origin":"","category":"sıfat","example":""},{"word":"aklı","length":4,"definition":"Beyazı bulunan, beyaz renkli","origin":"","category":"sıfat","example":""},{"word":"edep","length":4,"definition":"Toplum töresine uygun davranma","origin":"Arapça","category":"isim","example":""},{"word":"rücu","length":4,"definition":"Geri dönme, sözünü geri alma; cayma, tersinme","origin":"Arapça","category":"isim","example":""},{"word":"veri","length":4,"definition":"Bir araştırmanın, bir tartışmanın, bir muhakemenin temeli olan ana öge; muta (I), data, done","origin":"","category":"isim","example":""},{"word":"acve","length":4,"definition":"Medine'de yetişen, koyu renkli, tombul çekirdekli iyi cins bir tür hurma","origin":"Arapça","category":"isim","example":""},{"word":"meal","length":4,"definition":"Arapçadan kelime kelime çevirmeksizin, asıl anlatılmak istenileni ifade ederek yapılan Kur’an çevirilerinin ortak adı","origin":"Arapça","category":"isim","example":""},{"word":"bazı","length":4,"definition":"(nesne için) Bir kısım, bir miktar","origin":"Arapça","category":"isim","example":""},{"word":"adak","length":4,"definition":"Adanılan şey; nezir","origin":"","category":"isim","example":