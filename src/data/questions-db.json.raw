mple":""},{"word":"adamcıl","length":7,"definition":"İnsandan ürkmeyen, insana alışmış olan, insana sokulan, sıcakkanlı, munis","origin":"","category":"sıfat","example":""},{"word":"anayasa","length":7,"definition":"Bir devletin yönetim biçimini belirten, yasama, yürütme, yargılama güçlerinin nasıl kullanılacağını gösteren, yurttaşların kamu haklarını bildiren temel yasa; kanunuesasi","origin":"","category":"isim","example":""},{"word":"asılsız","length":7,"definition":"Doğru olmayan, temelsiz, köksüz, dayanaksız, yalan (haber)","origin":"","category":"sıfat","example":""},{"word":"Abazaca","length":7,"definition":"Abazalar tarafından kullanılan dil; Abhazca","origin":"","category":"isim","example":""},{"word":"iyimser","length":7,"definition":"Genellikle her düşünce ve işi iyi olarak değerlendiren; nikbin, optimist, kötümser karşıtı","origin":"","category":"sıfat","example":""},{"word":"kefenli","length":7,"definition":"Kefene sarılmış","origin":"","category":"sıfat","example":""},{"word":"andante","length":7,"definition":"Adacyo ile andantino arası, yarı yavaş bir biçimde (çalınmak)","origin":"İtalyanca","category":"zarf","example":""},{"word":"açınmak","length":7,"definition":"Uyurken üzerindeki yorgan ve örtüyü atmak","origin":"","category":"nesnesiz","example":""},{"word":"bedelli","length":7,"definition":"Bedeli olan, bedeli ödenen","origin":"","category":"sıfat","example":""},{"word":"kalkmak","length":7,"definition":"Oturmaktayken veya yatmaktayken gitmek üzere yerinden ayrılmak","origin":"","category":"nesnesiz","example":""},{"word":"belgili","length":7,"definition":"Belgiye dayanan, belirli olan","origin":"","category":"sıfat","example":""},{"word":"kakımak","length":7,"definition":"Bir kimsenin yaptığı işin beğenilmediğini kendisine sert sözlerle söylemek","origin":"","category":"-i","example":""},{"word":"bilezik","length":7,"definition":"Genellikle altın, gümüş vb. elementlerden yapılan ve bileğe süs için takılan halka","origin":"","category":"isim","e