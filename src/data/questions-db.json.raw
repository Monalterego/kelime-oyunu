igin":"Fransızca","category":"isim","example":""},{"word":"breş","length":4,"definition":"Doğal çimento ile lavlı, kavkılı, kabuklu, kemikli kırıntıların kaynaşmasıyla oluşmuş kütle","origin":"Fransızca","category":"isim","example":""},{"word":"ağcı","length":4,"definition":"Ağ ile balık tutarak geçinen kimse","origin":"","category":"isim","example":""},{"word":"selp","length":4,"definition":"Zorla alma, kapma","origin":"Arapça","category":"isim","example":""},{"word":"Foça","length":4,"definition":"İzmir iline bağlı ilçelerden biri","origin":"","category":"isim","example":""},{"word":"gele","length":4,"definition":"Tavla oyununda elinde kırık taşı bulunan oyuncunun attığı, oyuna devam etmesine yaramayan zar","origin":"","category":"isim","example":""},{"word":"denk","length":4,"definition":"Yük hayvanlarının sağ ve soluna konulan iki yük parçasından her biri","origin":"","category":"isim","example":""},{"word":"irin","length":4,"definition":"Organizmanın herhangi bir yerinde iltihaplanma sonunda ölmüş hücre artıklarından ve bozulmuş akyuvarlardan oluşan, mikroplu veya mikropsuz, genellikle sarımtırak renkte koyuca sıvı; cerahat, ufunet","origin":"","category":"isim","example":""},{"word":"şive","length":4,"definition":"Söyleyiş özelliği","origin":"Farsça","category":"isim","example":""},{"word":"eril","length":4,"definition":"Cinsiyet kategorisinin söz konusu olduğu dillerde erkek cinsten sayılan (kelime); müzekker","origin":"","category":"sıfat","example":""},{"word":"arış","length":4,"definition":"Kolun dirsekten parmaklara kadar olan bölümü","origin":"Farsça","category":"isim","example":""},{"word":"volt","length":4,"definition":"Elektromotor gücün veya gerilimin birimi","origin":"Fransızca","category":"isim","example":""},{"word":"etki","length":4,"definition":"Bir kimse veya nesnenin başka bir kişi veya şey üzerindeki .......leme gücü; yardım, tesir, rol","origin":"","category":"isim","example":""},{"word":"salt","length":4,"definition":"İçinde yabancı bir öge