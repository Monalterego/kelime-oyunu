":"isim","example":""},{"word":"üçüz","length":4,"definition":"Üçü bir arada doğan (çocuk)","origin":"","category":"sıfat","example":""},{"word":"üçlü","length":4,"definition":"Üç parçadan oluşan, kendinde herhangi bir şeyden üç tane bulunan; müselles, troyka","origin":"","category":"sıfat","example":""},{"word":"küre","length":4,"definition":"Bütün noktaları merkezden aynı uzaklıkta bulunan bir yüzeyle sınırlı cisim","origin":"Arapça","category":"isim","example":""},{"word":"vaaz","length":4,"definition":"Cami, mescit vb. yerlerde vaizlerin yaptığı, genellikle öğüt niteliği taşıyan dinî konuşma; mevize","origin":"Arapça","category":"isim","example":""},{"word":"müze","length":4,"definition":"Sanat ve bilim eserlerinin veya sanat ve bilime yarayan nesnelerin saklandığı, halka gösterilmek için sergilendiği yer","origin":"Fransızca","category":"isim","example":""},{"word":"tema","length":4,"definition":"Asıl konu, temel motif; ana konu","origin":"İtalyanca","category":"isim","example":""},{"word":"anüs","length":4,"definition":"Sindirim sisteminin sonunda bulunan ve dışkının atılmasına yarayan çıkış deliği; büzük, göt, makat, sofra, şerç","origin":"Fransızca","category":"isim","example":""},{"word":"veya","length":4,"definition":"Ayrı olmakla birlikte aynı değerde tutulan iki şeyi anlatan kelimelerden ikincisinin önüne getirilen söz; yahut, .......hut","origin":"Arapça","category":"bağlaç","example":""},{"word":"judo","length":4,"definition":"Jiujitsudan gelişmiş, tutmalara, fırlatmalara, hareketsiz bırakmalara dayanan, Japon kökenli silahsız yapılan dövüş sporu","origin":"Fransızca","category":"isim","example":""},{"word":"ofis","length":4,"definition":"Bir işletmeyi veya hizmeti yönetmek üzere düzenleme faaliyetlerinin yapıldığı alan","origin":"Fransızca","category":"isim","example":""},{"word":"besi","length":4,"definition":"Yaşatmak ve geliştirmek için gereken .......nleri yedirip içirme işi","origin":"","category":"isim","example":""},{"word":"Noel","length":4,"definition":"Hristiyanların her yıl 25 Aralık'ta Hz. İsa'nın doğum gününü kutladıkları yortu","origin":"Fransızca","category":"isim","example":""},{"word":"cüda","length":4,"definition":"Yurt, baba ocağı gibi çok sevilen şeylerden ayrılmış olan, uzak kalmış olan","origin":"Farsça","category":"sıfat","example":""},{"word":"vasi","length":4,"definition":"Bir yetimin veya akılca zayıf, hasta birinin malını yöneten kimse","origin":"Arapça","category":"isim","example":""},{"word":"yapı","length":4,"definition":"Barınmak veya başka amaçlarla kullanılmak için .......lmış her türlü mimarlık eseri; bina, mimari","origin":"","category":"isim","example":""},{"word":"illa","length":4,"definition":"Ne olursa olsun, hangi şartta olursa olsun; ille, .......ki","origin":"Arapça","category":"zarf","example":""},{"word":"azot","length":4,"definition":"Atom numarası 7, atom ağırlığı 14,008 olan, havada beşte dört oranında bulunan, rengi, kokusu, tadı olmayan element; nitrojen (simgesi N)","origin":"Fransızca","category":"isim","example":""},{"word":"lapa","length":4,"definition":"Nişastalı tanelerin, su ile kaynatılarak bulamaç kıvamına getirilmiş durumu","origin":"Rumca","category":"isim","example":""},{"word":"mola","length":4,"definition":"Yorgunluğu gidermek için duraklama","origin":"İtalyanca","category":"isim","example":""},{"word":"Acem","length":4,"definition":"Klasik Türk müziğinde kullanılan birleşik bir makam","origin":"Arapça","category":"isim","example":""},{"word":"ilçe","length":4,"definition":"Yönetim bakımından yurt bölümlemesinde ilden sonra gelen bölüm; kaymakamlık, kaza","origin":"","category":"isim","example":""},{"word":"ekru","length":4,"definition":"Krem rengine yakın beyaz","origin":"İngilizce","category":"isim","example":""},{"word":"liga","length":4,"definition":"Üç deniz mili uzunluğunda bir ölçü birimi","origin":"İtalyanca","category":"isim","example":""},{"word":"anaç","length":4,"definition":"Şefkatli, anne gibi davranan","origin":"","category":"sıfat","example":""},{"word":"ecza","length":4,"definition":"Canlılardaki rahatsızlıkların bozuklukların ve çeşitli hastalıkların tanısı, önlenmesi veya tedavisi için yararlanılan doğal veya sentez yoluyla hazırlanmış madde","origin":"Arapça","category":"isim","example":""},{"word":"bayi","length":4,"definition":"Herhangi bir ürünü ana firma adına satma yetkisi olan kimse, dükkân veya kuruluş","origin":"Arapça","category":"isim","example":""},{"word":"kule","length":4,"definition":"Çoğunlukla kare veya silindir biçimindeki yüksek yapı","origin":"Arapça","category":"isim","example":""},{"word":"gazi","length":4,"definition":"Savaştan sağ olarak dönen kimse","origin":"Arapça","category":"isim","example":""},{"word":"ciro","length":4,"definition":"Bir ticaret senedinin alacaklı tarafından arkasına gereken yazının yazılıp imza edilerek üçüncü bir kişiye devredilmesi","origin":"İtalyanca","category":"isim","example":""},{"word":"dolu","length":4,"definition":"Havada su buğusunun birden yoğunlaşıp katılaşmasından oluşan, türlü irilikte, yuvarlak veya düzensiz biçimli buz parçaları durumunda yere hızla düşen bir yağış türü; kırcı","origin":"","category":"isim","example":""},{"word":"ahir","length":4,"definition":"Sıralamada sonuncu olan","origin":"Arapça","category":"sıfat","example":""},{"word":"dink","length":4,"definition":"Pirinci kabuğundan ayırmak veya bulgur dövmek için kullanılan dibek","origin":"","category":"isim","example":""},{"word":"dişi","length":4,"definition":"Yumurta oluşturan veya yavru doğuran (birey)","origin":"","category":"sıfat","example":""},{"word":"sten","length":4,"definition":"Çapı 9 milimetre olan, İngiliz yapısı, hafif, kullanışı kolay bir tür makineli tüfek","origin":"İngilizce","category":"isim","example":""},{"word":"söve","length":4,"definition":"Kapı ve pencerenin yerleştiği kasa, çerçeve","origin":"","category":"isim","example":""},{"word":"cart","length":4,"definition":"Sert bir şey yırtılırken çıkan ses","origin":"","category":"isim","example":""},{"word":"ülkü","length":4,"definition":"Amaç edinilen, ulaşılmak istenen şey; dava, ideal","origin":"","category":"isim","example":""},{"word":"meke","length":4,"definition":"Su kıyılarındaki böcekleri yiyerek yaşayan yaban ördeği","origin":"","category":"isim","example":""},{"word":"isli","length":4,"definition":"İsi olan, islenmiş, is bulaşmış","origin":"","category":"sıfat","example":""},{"word":"kötü","length":4,"definition":"İstenilen, beğenilen nitelikte olmayan, hoşa gitmeyen; bet (III), yaş (II), yavuz, bed, berbat, fena (I), iyi karşıtı","origin":"","category":"sıfat","example":""},{"word":"apel","length":4,"definition":"Anonim ortaklıklarda sermaye artırımı için yapılan ödeme çağrısı","origin":"Fransızca","category":"isim","example":""},{"word":"alık","length":4,"definition":"Anlama ve sezme gücü yetersiz olan (kimse)","origin":"","category":"sıfat","example":""},{"word":"ışkı","length":4,"definition":"Derilerin fazlalıklarını ve yağlarını kazımak ve tahtaları yontmak için kullanılan iki ucu saplı, eğri bıçak","origin":"","category":"isim","example":""},{"word":"lala","length":4,"definition":"Çocuğun bakım, eğitim ve öğretimiyle görevli kimse","origin":"Farsça","category":"isim","example":""},{"word":"vals","length":4,"definition":"Bir tür salon dansı","origin":"Fransızca","category":"isim","example":""},{"word":"yara","length":4,"definition":"Keskin bir şeyle veya bir vuruşla vücutta oluşan derin kesik; ceriha","origin":"","category":"isim","example":""},{"word":"ünlü","length":4,"definition":"Herkesçe bilinen, ün salmış olan; angın, adlı sanlı, anlı şanlı, şöhretli, tanınmış, meşhur, şanlı, namlı (I), namdar","origin":"","category":"sıfat","example":""},{"word":"inha","length":4,"definition":"Resmî bir göreve atama veya bir üst aşama için yazılan yazı","origin":"Arapça","category":"isim","example":""},{"word":"tarh","length":4,"definition":"Bahçelerde çiçek dikmeye ayrılmış yer","origin":"Arapça","category":"isim","example":""},{"word":"üzme","lengt