ategory":"nesnesiz","example":""},{"word":"kulakçık","length":8,"definition":"Kalbin üst bölümünde bulunan, sağdaki ana toplardamarlardan ve soldaki akciğer toplardamarlarından kanı alıp karıncıklara veren iki boşluğun adı","origin":"","category":"isim","example":""},{"word":"balıkçın","length":8,"definition":"Perde ayaklılardan, uzunca gagalı, uzun ve çatal kuyruklu, deniz kıyılarında yaşayan bir kuş cinsi; deniz kırlangıcı (Sterna hirundo)","origin":"","category":"isim","example":""},{"word":"heriflik","length":8,"definition":"Herif olma durumu, herife yakışır davranışta bulunma","origin":"","category":"isim","example":""},{"word":"darılgan","length":8,"definition":"Çabuk alınıp darılan (kimse)","origin":"","category":"sıfat","example":""},{"word":"közlemek","length":8,"definition":"Et, sebze, meyve, hamur vb.ni köz üzerinde pişirmek","origin":"","category":"-i","example":""},{"word":"yaslılık","length":8,"definition":"Yaslı olma durumu; matemlilik","origin":"","category":"isim","example":""},{"word":"ibretlik","length":8,"definition":"Ders alınacak nitelikte olan","origin":"","category":"sıfat","example":""},{"word":"sabunluk","length":8,"definition":"İçine sabun konulan küçük kap","origin":"","category":"isim","example":""},{"word":"puflamak","length":8,"definition":"\"Puf\" diye ses çıkararak sıkıntı veya üzüntüsünü belli etmek","origin":"","category":"nesnesiz","example":""},{"word":"küstahça","length":8,"definition":"Küstah, saygısız bir biçimde","origin":"","category":"zarf","example":""},{"word":"kemirici","length":8,"definition":"Kemirme özelliği olan","origin":"","category":"sıfat","example":""},{"word":"atacılık","length":8,"definition":"Uzaklarda bulunan ve birçok kuşaktan beri görünmeyen birtakım özelliklerin yeni bir kuşakta birden ortaya çıkması, ataya çekme; atavizm","origin":"","category":"isim","example":""},{"word":"müfettiş","length":8,"definition":"Kurum ve kuruluşlara genellikle habersiz olarak veya belli olayların şikâyeti üzerine gidip, işle